# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# Neon serverless Postgres connection string.
# Get one free at https://neon.tech → create project → copy the "pooled connection" string.
DATABASE_URL="postgresql://user:password@ep-xxxx.neon.tech/strophe?sslmode=require"

# Session signing secret — any random string 32+ chars. Generate with:
#   openssl rand -base64 32
SESSION_SECRET="replace-with-a-long-random-string-at-least-32-characters"

# OpenRouter — powers every AI Coach/Mentor feature.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-v1-..."

# Optional: override the default model used for AI features.
# Browse available models & their OpenRouter IDs at https://openrouter.ai/models
OPENROUTER_MODEL="anthropic/claude-sonnet-4.5"

# Used only in the HTTP-Referer header OpenRouter uses for its own analytics.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
